# VWAP+HTF Engine — Environment Variables
# Copy to .env and fill in your credentials

# ── Upstox API Credentials ──
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# ── OAuth Redirect URI ──
# Local:   http://localhost:5001/auth/callback
# Railway: https://your-app.railway.app/auth/callback
UPSTOX_REDIRECT_URI=http://localhost:5001/auth/callback

# ── Access Token (auto-managed after OAuth login) ──
UPSTOX_ACCESS_TOKEN=

# ── Database (Railway sets automatically, leave blank for local SQLite) ──
DATABASE_URL=

# ── Telegram (optional — trade alerts) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
